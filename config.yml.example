server:
  host: localhost
  port: 8765
  log_level: info
  workers: 1

database:
  path: ctf.db

wordlists:
  rockyou: wordlists/rockyou.txt
  ncl_common: wordlists/ncl-common.txt
  realuniq: realuniq.lst
  realhuman_phill: realhuman_phill.txt
  custom: []

crypto:
  auto_detect_timeout_ms: 800
  max_decode_depth: 5
  vigenere_max_key_len: 8
  xor_max_key_len: 16
  nist_english_freq: true

tools:
  hashcat_path: hashcat
  john_path: john
  tshark_path: tshark
  exiftool_path: exiftool
  binwalk_path: binwalk

performance:
  pcap_max_mb: 250
  pcap_async_threshold_mb: 10
  steg_async_threshold_mb: 5
  job_ttl_hours: 24

online_apis:
  crackstation: true
  hashes_com: true
  shodan_api_key: ''
  virustotal_key: ''
  timeout_s: 5

flag_patterns:
  - "NCL-[A-Z0-9]{4}-[0-9]+"
  - "flag\\{[^}]+\\}"
  - "HTB\\{[^}]+\\}"
  - "picoCTF\\{[^}]+\\}"
  - "ctf\\{[^}]+\\}"
